<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenBroadcaster.Avalonia.Views.AboutDialog"
        Width="500" Height="420" 
        Title="About OpenBroadcaster"
        CanResize="False"
        Background="{DynamicResource ObBrushBackground}"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterOwner">
  <Border Background="{DynamicResource ObBrushPanel}" Padding="24" Margin="12" CornerRadius="8">
    <StackPanel Spacing="16">
      <TextBlock Text="OpenBroadcaster" 
                 FontSize="28" 
                 FontWeight="Bold" 
                 Foreground="{DynamicResource ObBrushPrimaryText}" 
                 HorizontalAlignment="Center" />

      <TextBlock Text="{Binding AppVersion}"
             FontSize="12"
              Foreground="{DynamicResource ObBrushSecondaryText}"
             HorizontalAlignment="Center"
             Margin="0,-6,0,0" />
      
      <TextBlock Text="Professional Radio Automation Software" 
                 FontSize="14" 
                 Foreground="{DynamicResource ObBrushSecondaryText}" 
                 HorizontalAlignment="Center" 
                 Margin="0,0,0,8" />
      
      <Border Background="{DynamicResource ObBrushSurface}" Padding="16" CornerRadius="6">
        <StackPanel Spacing="12">
          <StackPanel>
            <TextBlock Text="Created by" Foreground="{DynamicResource ObBrushMutedText}" FontSize="12" />
            <TextBlock Text="Josh Rundle" FontSize="16" Foreground="{DynamicResource ObBrushPrimaryText}" FontWeight="SemiBold" />
          </StackPanel>
          
          <Separator Background="{DynamicResource ObBrushBorder}" />
          
          <StackPanel>
            <TextBlock Text="Support" Foreground="{DynamicResource ObBrushMutedText}" FontSize="12" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Twitch:" FontSize="14" Foreground="{DynamicResource ObBrushSecondaryText}" />
              <TextBlock Text="twitch.tv/bluntforcejosh" 
                         FontSize="14" 
                         Foreground="{DynamicResource ObBrushAccent}" 
                         FontWeight="SemiBold"
                         Cursor="Hand"
                         PointerPressed="OnTwitchClick" />
            </StackPanel>
          </StackPanel>
          
          <Separator Background="{DynamicResource ObBrushBorder}" />
          
          <StackPanel>
            <TextBlock Text="Source Code" Foreground="{DynamicResource ObBrushMutedText}" FontSize="12" />
            <TextBlock Text="github.com/WickedMediaSolutions/openbroadcaster" 
                       FontSize="14" 
                       Foreground="{DynamicResource ObBrushAccent}" 
                       FontWeight="SemiBold"
                       Cursor="Hand"
                       PointerPressed="OnGitHubClick" />
          </StackPanel>
        </StackPanel>
      </Border>
      
      <Button Content="Close" 
              Width="120" 
              Height="32"
              HorizontalAlignment="Center" 
              Click="OnCloseClick"
              Margin="0,8,0,0"
              Background="{DynamicResource ObBrushWindowButton}"
              Foreground="{DynamicResource ObBrushPrimaryText}"
              FontSize="14"
              FontWeight="SemiBold" />
    </StackPanel>
  </Border>
</Window>
