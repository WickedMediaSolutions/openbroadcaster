<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="https://github.com/avaloniaui/design"
        xmlns:vm="clr-namespace:OpenBroadcaster.Avalonia.ViewModels"
        xmlns:conv="clr-namespace:OpenBroadcaster.Avalonia.Converters"
        xmlns:ctrl="clr-namespace:OpenBroadcaster.Avalonia.Controls"
        x:Class="OpenBroadcaster.Avalonia.Views.MainWindow"
        Title="OpenBroadcaster (Avalonia)"
        Width="1200" Height="820"
  Background="{DynamicResource ObBrushBackground}"
  SystemDecorations="None">

  <Window.Resources>
    <conv:IsPlayingToBorderThicknessConverter x:Key="IsPlayingToBorderThicknessConverter" />
    <conv:CartPadVisualStateConverter x:Key="CartPadVisualStateConverter" />
    <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="ToggleButton.consoleRackButton">
      <Setter Property="Background" Value="{DynamicResource ObBrushSurface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ObBrushBorder}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Foreground" Value="{DynamicResource ObBrushPrimaryText}" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Foreground="{TemplateBinding Foreground}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
  </Window.Styles>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Title bar / menu -->
    <Border Background="{DynamicResource ObBrushPanel}" Padding="10" Grid.Row="0" CornerRadius="6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Menu VerticalAlignment="Center">
          <MenuItem Header="_File">
            <MenuItem Header="Exit" Click="OnExitClick" />
          </MenuItem>
          <MenuItem Header="_Library">
            <MenuItem Header="Manage Categories..." Command="{Binding ManageCategoriesCommand}" />
            <Separator />
            <MenuItem Header="Import Tracks" Command="{Binding ImportTracksCommand}" />
            <MenuItem Header="Scan Folders" Command="{Binding ImportFolderCommand}" />
          </MenuItem>
          <MenuItem Header="_Help">
            <MenuItem Header="About OpenBroadcaster" Command="{Binding OpenAboutDialogCommand}" />
          </MenuItem>
        </Menu>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="Theme" Foreground="{DynamicResource ObBrushSecondaryText}" VerticalAlignment="Center" />
          <ComboBox Width="170" Items="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" VerticalAlignment="Center" />
          <Button Content="App Settings" Command="{Binding OpenAppSettingsCommand}" Width="140" Margin="8,0" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="1">
          <Button Width="44" Height="32" Click="MinimizeButton_Click" 
                  Background="{DynamicResource ObBrushWindowButton}" 
                  BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1"
                  CornerRadius="4"
                  FontSize="16"
                  Foreground="{DynamicResource ObBrushPrimaryText}">
            <TextBlock Text="─" VerticalAlignment="Center" Margin="0,-4,0,0" />
          </Button>
          <Button Width="44" Height="32" Click="MaximizeRestoreButton_Click" 
                  Background="{DynamicResource ObBrushWindowButton}" 
                  BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1"
                  CornerRadius="4"
                  FontSize="14"
                  Foreground="{DynamicResource ObBrushPrimaryText}">
            <TextBlock Text="▢" VerticalAlignment="Center" />
          </Button>
          <Button Width="44" Height="32" Click="CloseButton_Click" 
                  Background="{DynamicResource ObBrushCloseButton}" 
                  BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1"
                  CornerRadius="4"
                  FontSize="16"
                  Foreground="{DynamicResource ObBrushPrimaryText}">
            <TextBlock Text="✕" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main content area -->
    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.1*" />
        <ColumnDefinition Width="1.9*" />
      </Grid.ColumnDefinitions>

      <!-- Left Column: Library + Twitch -->
      <Border Grid.Column="0" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="0,0,14,0">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Song Library" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
          </Grid>

          <Grid Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Watermark="Search your library" Text="{Binding LibrarySearchText}" />
            <ComboBox Grid.Column="1" Items="{Binding LibraryCategories}" SelectedItem="{Binding SelectedLibraryCategory}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Add to Queue" Command="{Binding AddToQueueCommand}" CommandParameter="{Binding SelectedLibraryItem}" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
            <Button Content="Assign Categories" Command="{Binding AssignCategoriesCommand}" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
            <Button Content="Import Files" Command="{Binding ImportTracksCommand}" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
            <Button Content="Import Folder" Command="{Binding ImportFolderCommand}" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
          </StackPanel>

          <TextBlock Margin="0,8,0,8" Foreground="{DynamicResource ObBrushSecondaryText}" Text="{Binding LibraryStatusMessage}" />

          <ListBox Name="LibraryList" Items="{Binding LibraryItems}" SelectedItem="{Binding SelectedLibraryItem}" Height="260" Margin="0,6,0,0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource ObBrushBackground}" Padding="8" CornerRadius="3" Margin="0,2">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="200" />
                      <ColumnDefinition Width="130" />
                      <ColumnDefinition Width="150" />
                      <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Title}" Foreground="{DynamicResource ObBrushPrimaryText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Text="{Binding Artist}" Foreground="{DynamicResource ObBrushSecondaryText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="{Binding Album}" Foreground="{DynamicResource ObBrushSecondaryText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3" Text="{Binding Duration}" Foreground="{DynamicResource ObBrushMutedText}" HorizontalAlignment="Right" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Background="{DynamicResource ObBrushBackground}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="6" Margin="0,8,0,0" Padding="6" Height="120">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Width="100" Height="100" Background="{DynamicResource ObBrushSurface}" CornerRadius="4" HorizontalAlignment="Left">
                <Image Source="{Binding SelectedLibraryItemArt}" Stretch="UniformToFill" />
              </Border>
              <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Selected Item Preview" Foreground="{DynamicResource ObBrushPrimaryText}" />
                <TextBlock Text="{Binding SelectedLibraryItem.Title, FallbackValue=''}" Foreground="{DynamicResource ObBrushSecondaryText}" />
                <TextBlock Text="{Binding SelectedLibraryItem.Artist, FallbackValue=''}" Foreground="{DynamicResource ObBrushSecondaryText}" />
              </StackPanel>
            </Grid>
          </Border>

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0">
            <TextBlock Text="Twitch Chat" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="18" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
              <TextBlock Text="Font" Foreground="{DynamicResource ObBrushSecondaryText}" Margin="4,0" VerticalAlignment="Center" />
              <Slider Minimum="8" Maximum="20" Value="{Binding TwitchChatFontSize, Mode=TwoWay}" Width="80" />
            </StackPanel>
          </StackPanel>

          <Border Background="{DynamicResource ObBrushBackground}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="6" Margin="0,8,0,0" Padding="6">
            <ListBox Name="ChatList" Items="{Binding ChatMessages}" Height="180" Background="Transparent" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource ObBrushMutedText}" Margin="0,0,8,0" FontSize="{Binding DataContext.TwitchChatFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" Margin="0,0,8,0" FontSize="{Binding DataContext.TwitchChatFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="{Binding DataContext.TwitchChatFontSize, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </StackPanel>
      </Border>

      <!-- Right Column: Decks, Queue, Cart Wall -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="2*" />
          <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="0.7*" />
        </Grid.ColumnDefinitions>

        <!-- Deck A -->
        <Border Name="DeckADropTarget" Grid.Row="0" Grid.Column="0" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="0,0,8,8"
                DragDrop.AllowDrop="True">
          <StackPanel>
            <TextBlock Text="Deck A" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="16" FontWeight="SemiBold" />
            <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,8,0,0">
              <StackPanel>
                <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Width="80" Height="80" Background="{DynamicResource ObBrushSurface}" CornerRadius="4" Margin="0,0,12,0">
                <Grid>
                  <Image Source="{Binding DeckA.AlbumArt}" Stretch="UniformToFill" />
                  <Border Background="{DynamicResource ObBrushSurface}" IsVisible="{Binding DeckA.AlbumArt, Converter={x:Static conv:NullToBoolConverter.Instance}, ConverterParameter=inverse}">
                    <TextBlock Text="No Art" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ObBrushSecondaryText}" />
                  </Border>
                </Grid>
              </Border>
              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding DeckA.Title}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="14" />
                <TextBlock Text="{Binding DeckA.Artist}" Foreground="{DynamicResource ObBrushSecondaryText}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                  <TextBlock Text="Elapsed:" Foreground="{DynamicResource ObBrushMutedText}" FontSize="11" />
                  <TextBlock Text="{Binding DeckA.ElapsedTime}" Foreground="{DynamicResource ObBrushAccent}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="13" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Remaining:" Foreground="{DynamicResource ObBrushMutedText}" FontSize="11" />
                  <TextBlock Text="{Binding DeckA.RemainingTime}" Foreground="{DynamicResource ObBrushAccent}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="13" FontWeight="Bold" />
                </StackPanel>
              </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="4">
                  <Button Content="Play" Width="80" Command="{Binding DeckPlayCommand}" CommandParameter="A" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                  <Button Content="Stop" Width="80" Command="{Binding DeckStopCommand}" CommandParameter="A" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                  <Button Content="Next" Width="80" Command="{Binding DeckNextCommand}" CommandParameter="A" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Deck B -->
        <Border Name="DeckBDropTarget" Grid.Row="0" Grid.Column="1" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="8,0,8,8"
                DragDrop.AllowDrop="True">
          <StackPanel>
            <TextBlock Text="Deck B" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="16" FontWeight="SemiBold" />
            <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,8,0,0">
              <StackPanel>
                <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Width="80" Height="80" Background="{DynamicResource ObBrushSurface}" CornerRadius="4" Margin="0,0,12,0">
                <Grid>
                  <Image Source="{Binding DeckB.AlbumArt}" Stretch="UniformToFill" />
                  <Border Background="{DynamicResource ObBrushSurface}" IsVisible="{Binding DeckB.AlbumArt, Converter={x:Static conv:NullToBoolConverter.Instance}, ConverterParameter=inverse}">
                    <TextBlock Text="No Art" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ObBrushSecondaryText}" />
                  </Border>
                </Grid>
              </Border>
              <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding DeckB.Title}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="14" />
                <TextBlock Text="{Binding DeckB.Artist}" Foreground="{DynamicResource ObBrushSecondaryText}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                  <TextBlock Text="Elapsed:" Foreground="{DynamicResource ObBrushMutedText}" FontSize="11" />
                  <TextBlock Text="{Binding DeckB.ElapsedTime}" Foreground="{DynamicResource ObBrushAccent}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="13" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Remaining:" Foreground="{DynamicResource ObBrushMutedText}" FontSize="11" />
                  <TextBlock Text="{Binding DeckB.RemainingTime}" Foreground="{DynamicResource ObBrushAccent}" FontFamily="OCR A Extended, Consolas, Courier New" FontSize="13" FontWeight="Bold" />
                </StackPanel>
              </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="4">
                  <Button Content="Play" Width="80" Command="{Binding DeckPlayCommand}" CommandParameter="B" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                  <Button Content="Stop" Width="80" Command="{Binding DeckStopCommand}" CommandParameter="B" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                  <Button Content="Next" Width="80" Command="{Binding DeckNextCommand}" CommandParameter="B" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Control Rack -->
        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="8,0,0,8">
          <StackPanel>
            <TextBlock Text="Control Rack" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="16" FontWeight="SemiBold" />

            <Border Margin="0,8,0,4"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    Padding="0">
              <Grid Width="190" Height="78">
                <Image Stretch="Uniform"
                       Source="avares://OpenBroadcaster.Avalonia/Assets/on-air-custom.png" />
                <Border Background="#D0FF2A2A"
                        Opacity="{Binding OnAir, Converter={x:Static conv:BoolToOpacityConverter.Instance}, ConverterParameter='0.55|0'}"
                        IsHitTestVisible="False">
                  <Border.OpacityMask>
                    <ImageBrush Source="avares://OpenBroadcaster.Avalonia/Assets/on-air-custom.png" Stretch="Uniform" />
                  </Border.OpacityMask>
                </Border>
              </Grid>
            </Border>
            
            <!-- Toggle Buttons at Top -->
            <Grid Margin="0,8,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              
              <ToggleButton Grid.Column="0" Classes="consoleRackButton" IsChecked="{Binding TwitchChatEnabled}" Width="58" Height="58" HorizontalAlignment="Center" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="29">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse Width="10" Height="10" Margin="0,0,0,4" HorizontalAlignment="Center"
                           Stroke="{DynamicResource ObBrushBorder}" StrokeThickness="1"
                           Fill="{Binding TwitchChatEnabled, Converter={x:Static conv:BoolToBrushConverter.Instance}, ConverterParameter='resource:ObBrushToggleOn|resource:ObBrushToggleOff'}" />
                  <TextBlock Text="Twitch" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
              </ToggleButton>
              
              <ToggleButton Grid.Column="1" Classes="consoleRackButton" IsChecked="{Binding AutoDjEnabled}" Width="58" Height="58" HorizontalAlignment="Center" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="29">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse Width="10" Height="10" Margin="0,0,0,4" HorizontalAlignment="Center"
                           Stroke="{DynamicResource ObBrushBorder}" StrokeThickness="1"
                           Fill="{Binding AutoDjEnabled, Converter={x:Static conv:BoolToBrushConverter.Instance}, ConverterParameter='resource:ObBrushToggleOn|resource:ObBrushToggleOff'}" />
                  <TextBlock Text="AutoDJ" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
              </ToggleButton>
              
              <ToggleButton Grid.Column="2" Classes="consoleRackButton" IsChecked="{Binding EncodersEnabled}" Width="58" Height="58" HorizontalAlignment="Center" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="29">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse Width="10" Height="10" Margin="0,0,0,4" HorizontalAlignment="Center"
                           Stroke="{DynamicResource ObBrushBorder}" StrokeThickness="1"
                           Fill="{Binding EncodersEnabled, Converter={x:Static conv:BoolToBrushConverter.Instance}, ConverterParameter='resource:ObBrushToggleOn|resource:ObBrushToggleOff'}" />
                  <TextBlock Text="Encode" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
              </ToggleButton>

              <ToggleButton Grid.Column="3" Classes="consoleRackButton" IsChecked="{Binding MicEnabled}" Width="58" Height="58" HorizontalAlignment="Center" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="29">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse Width="10" Height="10" Margin="0,0,0,4" HorizontalAlignment="Center"
                           Stroke="{DynamicResource ObBrushBorder}" StrokeThickness="1"
                           Fill="{Binding MicEnabled, Converter={x:Static conv:BoolToBrushConverter.Instance}, ConverterParameter='resource:ObBrushToggleOn|resource:ObBrushToggleOff'}" />
                  <TextBlock Text="Talk" FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
              </ToggleButton>
            </Grid>
            
            <StackPanel>
              <Grid Margin="0,0,0,0">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Program / Main Output -->
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,4">
                  <TextBlock Text="Main" Foreground="{DynamicResource ObBrushSecondaryText}" FontSize="13" FontWeight="SemiBold" />
                  <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="4" Padding="6" Margin="0,3,0,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      
                      <!-- Left side: Vol label, Knob, and % -->
                      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock 
                          Text="Vol" 
                          Foreground="{DynamicResource ObBrushSecondaryText}" 
                          Margin="0,0,0,4" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="10" />
                        <ctrl:RotaryKnob 
                          Value="{Binding MasterVolume, Mode=TwoWay}" 
                          Minimum="0" 
                          Maximum="100" 
                          Width="45" 
                          Height="45"
                          Margin="0,0,0,4"
                          KnobBrush="#0A0A0A"
                          IndicatorBrush="#FFFFFF"
                          BackgroundBrush="#000000" />
                        <TextBlock 
                          Text="{Binding MasterVolume, StringFormat='{}{0}%'}" 
                          Foreground="{DynamicResource ObBrushAccent}" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="13" />
                      </StackPanel>
                      
                      <!-- Right side: Power Meter -->
                      <ctrl:PowerMeter 
                        Grid.Column="1"
                        Value="{Binding ProgramVuPercent}" 
                        Minimum="0" 
                        Maximum="100" 
                        Height="62"
                        MinWidth="132"
                        NeedleBrush="{DynamicResource ObBrushAccent}"
                        MeterBackground="{DynamicResource ObBrushPanel}"
                        ScaleBrush="{DynamicResource ObBrushSecondaryText}" />
                    </Grid>
                  </Border>
                </StackPanel>

                <!-- Mic -->
                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,4">
                  <TextBlock Text="Mic" Foreground="{DynamicResource ObBrushSecondaryText}" FontSize="13" FontWeight="SemiBold" />
                  <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="4" Padding="6" Margin="0,3,0,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      
                      <!-- Left side: Vol label, Knob, and % -->
                      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock 
                          Text="Vol" 
                          Foreground="{DynamicResource ObBrushSecondaryText}" 
                          Margin="0,0,0,4" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="10" />
                        <ctrl:RotaryKnob 
                          Value="{Binding MicVolume, Mode=TwoWay}" 
                          Minimum="0" 
                          Maximum="100" 
                          Width="45" 
                          Height="45"
                          Margin="0,0,0,4"
                          KnobBrush="#0A0A0A"
                          IndicatorBrush="#FFFFFF"
                          BackgroundBrush="#000000" />
                        <TextBlock 
                          Text="{Binding MicVolume, StringFormat='{}{0}%'}" 
                          Foreground="{DynamicResource ObBrushAccent}" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="12" />
                      </StackPanel>
                      
                      <!-- Right side: Power Meter -->
                      <ctrl:PowerMeter 
                        Grid.Column="1"
                        Value="{Binding MicVuPercent}" 
                        Minimum="0" 
                        Maximum="100" 
                        Height="62"
                        MinWidth="132"
                        NeedleBrush="{DynamicResource ObBrushAccent}"
                        MeterBackground="{DynamicResource ObBrushPanel}"
                        ScaleBrush="{DynamicResource ObBrushSecondaryText}" />
                    </Grid>
                  </Border>
                </StackPanel>

                <!-- Cart Wall -->
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,4">
                  <TextBlock Text="Cart Wall" Foreground="{DynamicResource ObBrushSecondaryText}" FontSize="13" FontWeight="SemiBold" />
                  <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="4" Padding="6" Margin="0,3,0,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      
                      <!-- Left side: Vol label, Knob, and % -->
                      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock 
                          Text="Vol" 
                          Foreground="{DynamicResource ObBrushSecondaryText}" 
                          Margin="0,0,0,4" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="10" />
                        <ctrl:RotaryKnob 
                          Value="{Binding CartWallVolume, Mode=TwoWay}" 
                          Minimum="0" 
                          Maximum="100" 
                          Width="45" 
                          Height="45"
                          Margin="0,0,0,4"
                          KnobBrush="#0A0A0A"
                          IndicatorBrush="#FFFFFF"
                          BackgroundBrush="#000000" />
                        <TextBlock 
                          Text="{Binding CartWallVolume, StringFormat='{}{0}%'}" 
                          Foreground="{DynamicResource ObBrushAccent}" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="12" />
                      </StackPanel>
                      
                      <!-- Right side: Power Meter -->
                      <ctrl:PowerMeter 
                        Grid.Column="1"
                        Value="{Binding CartVuPercent}" 
                        Minimum="0" 
                        Maximum="100" 
                        Height="62"
                        MinWidth="132"
                        NeedleBrush="{DynamicResource ObBrushAccent}"
                        MeterBackground="{DynamicResource ObBrushPanel}"
                        ScaleBrush="{DynamicResource ObBrushSecondaryText}" />
                    </Grid>
                  </Border>
                </StackPanel>

                <!-- Encoder -->
                <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,4">
                  <TextBlock Text="Encoder" Foreground="{DynamicResource ObBrushSecondaryText}" FontSize="13" FontWeight="SemiBold" />
                  <Border Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="2" CornerRadius="4" Padding="6" Margin="0,3,0,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      
                      <!-- Left side: Vol label, Knob, and % -->
                      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock 
                          Text="Vol" 
                          Foreground="{DynamicResource ObBrushSecondaryText}" 
                          Margin="0,0,0,4" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="10" />
                        <ctrl:RotaryKnob 
                          Value="{Binding EncoderVolume, Mode=TwoWay}" 
                          Minimum="0" 
                          Maximum="100" 
                          Width="45" 
                          Height="45"
                          Margin="0,0,0,4"
                          KnobBrush="#0A0A0A"
                          IndicatorBrush="#FFFFFF"
                          BackgroundBrush="#000000" />
                        <TextBlock 
                          Text="{Binding EncoderVolume, StringFormat='{}{0}%'}" 
                          Foreground="{DynamicResource ObBrushAccent}" 
                          HorizontalAlignment="Center"
                          FontWeight="SemiBold"
                          FontSize="12" />
                      </StackPanel>
                      
                      <!-- Right side: Power Meter -->
                      <ctrl:PowerMeter 
                        Grid.Column="1"
                        Value="{Binding EncoderVuPercent}" 
                        Minimum="0" 
                        Maximum="100" 
                        Height="62"
                        MinWidth="132"
                        NeedleBrush="{DynamicResource ObBrushAccent}"
                        MeterBackground="{DynamicResource ObBrushPanel}"
                        ScaleBrush="{DynamicResource ObBrushSecondaryText}" />
                    </Grid>
                  </Border>
                </StackPanel>

                <!-- Digital Clock -->
                <TextBlock Grid.Row="4" Name="DigitalClock" Text="00:00:00" 
                           Foreground="{DynamicResource ObBrushAccent}" 
                           FontSize="28" FontFamily="Courier New" FontWeight="Bold" 
                           TextAlignment="Center" HorizontalAlignment="Center" 
                           VerticalAlignment="Center" Margin="0,8,0,8" />
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Queue (spans columns 0-1, below decks) -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="0,0,8,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Program Queue" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="16" FontWeight="SemiBold" />
              <Button Content="Shuffle" Command="{Binding ShuffleQueueCommand}" Margin="12,0,0,0" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
              <Button Content="Clear" Command="{Binding ClearQueueCommand}" Margin="8,0,0,0" Background="{DynamicResource ObBrushSurface}" BorderBrush="{DynamicResource ObBrushBorder}" BorderThickness="1" CornerRadius="4" />
            </StackPanel>

            <ListBox Name="QueueList" Grid.Row="1" Items="{Binding QueueItems}" SelectedItem="{Binding SelectedQueueItem}" Margin="0,12,0,0"
                     DragDrop.AllowDrop="True">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource ObBrushBackground}" 
                          BorderBrush="{DynamicResource ObBrushBorder}" 
                          BorderThickness="2" 
                          Padding="10" 
                          CornerRadius="6" 
                          Margin="0,4">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="200" />
                          <ColumnDefinition Width="140" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="70" />
                          <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource ObBrushPrimaryText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{Binding Artist}" Foreground="{DynamicResource ObBrushSecondaryText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="{DynamicResource ObBrushMutedText}" TextTrimming="CharacterEllipsis" Margin="8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding Duration}" Foreground="{DynamicResource ObBrushMutedText}" HorizontalAlignment="Right" />
                        <Button Grid.Column="4" Content="Remove" Command="{Binding DataContext.RemoveQueueItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Width="80" Margin="8,0,0,0" />
                      </Grid>
                      <Border Grid.Row="1"
                              Margin="0,6,0,0"
                              Padding="6,2"
                              CornerRadius="4"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ObBrushAccent}"
                              Background="{DynamicResource ObBrushAccentSoft}"
                              IsVisible="{Binding IsTwitchRequest}">
                        <TextBlock Text="{Binding RequestedByDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ObBrushAccent}" />
                      </Border>
                      <Border Grid.Row="1"
                              Margin="0,6,0,0"
                              Padding="6,2"
                              CornerRadius="4"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ObBrushAccent}"
                              Background="{DynamicResource ObBrushAccentSoft}"
                              IsVisible="{Binding IsWebRequest}">
                        <TextBlock Text="{Binding WebRequestDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ObBrushAccent}"
                                   TextWrapping="Wrap" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <!-- Cart Wall -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource ObBrushPanel}" CornerRadius="8" Padding="12" Margin="0,0,8,8">
          <StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Cart Wall" Foreground="{DynamicResource ObBrushPrimaryText}" FontSize="16" FontWeight="SemiBold" />
              <!-- Cart wall volume is shown in Control Rack -->
            </StackPanel>

            <ItemsControl Items="{Binding CartPads}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel ItemWidth="140" ItemHeight="80" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.TriggerCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                      CommandParameter="{Binding}"
                      Margin="6"
                      Background="{Binding RemainingTimeDisplay, Converter={x:Static conv:CartPadVisualStateConverter.Instance}, ConverterParameter=background}"
                      CornerRadius="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      BorderBrush="{Binding IsPlaying, Converter={x:Static conv:CartPadVisualStateConverter.Instance}, ConverterParameter=border}"
                      BorderThickness="{Binding IsPlaying, Converter={x:Static conv:CartPadVisualStateConverter.Instance}, ConverterParameter=thickness}"
                      x:Name="CartButton">
                    <Button.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Assign File..." Click="OnAssignFile" Tag="{Binding #CartButton.DataContext}" />
                        <MenuItem Header="Clear" Click="OnClearPad" Tag="{Binding #CartButton.DataContext}" />
                      </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource ObBrushPrimaryText}" />
                      <TextBlock Text="{Binding Hotkey}" Foreground="{DynamicResource ObBrushAccent}" FontSize="12" HorizontalAlignment="Center" FontWeight="Bold" />
                      <TextBlock Text="{Binding RemainingTimeDisplay}" Foreground="{DynamicResource ObBrushAccent}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
